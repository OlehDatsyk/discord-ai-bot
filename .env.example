# ============================================================
# Discord AI Bot - Environment Configuration
# Copy this file to ".env" and fill in your own values.
# NEVER commit your real ".env" file to Git.
# ============================================================

# ---- Discord ------------------------------------------------
# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Optional: your test server's Guild ID for instant slash-command sync.
# Leave empty to sync commands globally (takes up to 1 hour to appear).
DISCORD_GUILD_ID=

# ---- OpenAI ---------------------------------------------------
# API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MODERATION_MODEL=omni-moderation-latest
OPENAI_MAX_OUTPUT_TOKENS=800

# ---- Database ---------------------------------------------------
DATABASE_PATH=data/bot.db

# ---- Conversation memory -----------------------------------------
CONVERSATION_HISTORY_LIMIT=10

# ---- HTTP API (health check + automation webhooks) ----------------
API_HOST=0.0.0.0
API_PORT=8000
# Shared secret required in the X-Webhook-Secret header for /automation/* routes.
# Generate a strong random value, e.g. with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=change-me

# ---- Outbound automation webhooks (optional) -----------------------
# If set, the bot will POST events (e.g. flagged messages) to these URLs.
N8N_WEBHOOK_URL=
ZAPIER_WEBHOOK_URL=
MAKE_WEBHOOK_URL=

# ---- Logging ---------------------------------------------------
LOG_LEVEL=INFO
